# =============================================================================
# claude-recall Tiered Storage Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (Cold Tier)
# -----------------------------------------------------------------------------
# Connection string for PostgreSQL with pgvector extension
DATABASE_URL=postgres://postgres:postgres@localhost:5432/claude_recall

# Maximum connections in the pool
PG_MAX_CONNECTIONS=10

# How long to keep data before cleanup (days)
PG_RETENTION_DAYS=20

# -----------------------------------------------------------------------------
# Redis (Hot Tier)
# -----------------------------------------------------------------------------
# Redis server host
REDIS_HOST=localhost

# Redis server port
REDIS_PORT=6379

# Redis password (leave empty if none)
REDIS_PASSWORD=

# Redis database number
REDIS_DB=0

# How long to keep data in hot tier (seconds, default: 48 hours)
REDIS_HOT_TIER_TTL=172800

# -----------------------------------------------------------------------------
# Ollama (Embeddings)
# -----------------------------------------------------------------------------
# Ollama server URL
OLLAMA_HOST=http://localhost:11434

# Embedding model to use (nomic-embed-text recommended, 768 dimensions)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Embedding dimension (must match model)
OLLAMA_EMBEDDING_DIMENSION=768

# -----------------------------------------------------------------------------
# Search Settings
# -----------------------------------------------------------------------------
# Enable reranker for improved search quality (requires vLLM setup)
SEARCH_USE_RERANKER=false

# Reranker URL (if enabled)
# SEARCH_RERANKER_URL=http://localhost:8001

# Maximum tokens for context injection
SEARCH_TOKEN_BUDGET=2000

# Default number of results to return
SEARCH_DEFAULT_LIMIT=10

# Minimum hot tier results before querying cold tier
SEARCH_MIN_HOT_RESULTS=3

# -----------------------------------------------------------------------------
# Summarization (Background Workers)
# -----------------------------------------------------------------------------
# Delay before consolidating observations into session summaries (hours)
SUMMARIZATION_SESSION_CONSOLIDATION_DELAY_HOURS=24

# Delay before consolidating sessions into weekly summaries (days)
SUMMARIZATION_WEEKLY_CONSOLIDATION_DELAY_DAYS=7

# How often to run consolidation (milliseconds, default: 6 hours)
SUMMARIZATION_CONSOLIDATION_INTERVAL_MS=21600000

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------
# Host to bind the API server
CLAUDE_RECALL_SERVER_HOST=127.0.0.1

# Port for the API server
CLAUDE_RECALL_SERVER_PORT=37778

# Use local sentence-transformers instead of Ollama for embeddings
# Set to true if Ollama is not available
CLAUDE_RECALL_USE_LOCAL_EMBEDDINGS=false
